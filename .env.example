# Secrets da impostare su GitHub:
# Repository → Settings → Secrets and variables → Actions → New repository secret
#
# Oppure usa lo script di setup:
#   bash scripts/setup.sh        (Linux / macOS / WSL)
#   pwsh scripts/setup.ps1       (Windows PowerShell 7+)

# ── Vercel ────────────────────────────────────────────────────────────────────
# Token personale: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Ottenibili dopo "vercel link" da .vercel/project.json
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Token personale: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Reference ID del progetto (12 caratteri):
# Supabase Dashboard → Project Settings → General → Reference ID
SUPABASE_PROJECT_REF=
